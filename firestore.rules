rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.email is string &&
               data.email.size() <= 200;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'onboarded']);
    }

    // Transaction Rules
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid &&
               data.amount is number &&
               data.type in ['debit', 'credit'] &&
               data.merchant is string &&
               data.category is string &&
               data.date is string;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['category', 'merchant', 'amount', 'date']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Budget Rules
    match /budgets/{budgetId} {
      function isValidBudget(data) {
        return data.userId == request.auth.uid &&
               data.category is string &&
               data.limit is number &&
               data.month is string &&
               data.year is number;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBudget(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid &&
                      isValidBudget(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
